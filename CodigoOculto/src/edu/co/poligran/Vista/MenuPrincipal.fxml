<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane xmlns="http://javafx.com/javafx/25"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="edu.co.poligran.Controlador.MenuPrincipalControlador">

	<children>

		<!-- Fondo -->
		<ImageView fitHeight="463.0" fitWidth="689.0"
			pickOnBounds="true" preserveRatio="true">
			<image>
				<Image url="@/recursos/Fondo1.png" />
			</image>
		</ImageView>

		<!-- BOTÓN REGISTRARSE -->
		<Button layoutX="278.0" layoutY="72.0"
			onAction="#registrarJugador" prefHeight="32.0" prefWidth="157.0"
			style="-fx-background-color: linear-gradient(#4b4b4b, #1f1f1f); -fx-background-radius: 40;"
			text="Registrarse" textFill="WHITE">
			<font>
				<Font name="MT Extra" size="14.0" />
			</font>
		</Button>

		<!-- INPUT NOMBRE -->
		<Rectangle arcHeight="40.0" arcWidth="40.0" height="32.0"
			layoutX="214.0" layoutY="111.0" stroke="BLACK" strokeType="INSIDE"
			width="139.0" />

		<Text fill="WHITE" layoutX="235.0" layoutY="131.0" text="Name :">
			<font>
				<Font name="MT Extra" size="14.0" />
			</font>
		</Text>

		<TextField fx:id="txtNombre" layoutX="289.0" layoutY="111.0"
			prefHeight="32.0" prefWidth="199.0"
			style="-fx-background-color: linear-gradient(#4b4b4b, #1f1f1f);
                        -fx-background-radius: 40;
                        -fx-text-fill: white;
                        -fx-padding: 8 15 8 15;">
			<font>
				<Font name="MT Extra" size="14.0" />
			</font>
		</TextField>

		<!-- BOTÓN LOGIN -->
		<Button layoutX="277.0" layoutY="161.0"
			onAction="#iniciarSesion" prefHeight="32.0" prefWidth="157.0"
			style="-fx-background-color: linear-gradient(#4b4b4b, #1f1f1f); -fx-background-radius: 40;"
			text="Iniciar Sesión" textFill="WHITE">
			<font>
				<Font name="MT Extra" size="14.0" />
			</font>
		</Button>

		<!-- INPUT ID -->
		<Rectangle arcHeight="40.0" arcWidth="40.0" height="31.0"
			layoutX="245.0" layoutY="201.0" stroke="BLACK" strokeType="INSIDE"
			width="139.0" />

		<Text fill="WHITE" layoutX="258.0" layoutY="220.0" text="ID :">
			<font>
				<Font name="MT Extra" size="14.0" />
			</font>
		</Text>

		<TextField fx:id="txtId" layoutX="278.0" layoutY="200.0"
			prefHeight="32.0" prefWidth="185.0"
			style="-fx-background-color: linear-gradient(#4b4b4b, #1f1f1f);
                        -fx-background-radius: 40;
                        -fx-text-fill: white;
                        -fx-padding: 8 15 8 15;">
			<font>
				<Font name="MT Extra" size="14.0" />
			</font>
		</TextField>

		<!-- TEXTO DE ERROR (IMPORTANTE PARA AUTENTICACIÓN) -->
		<Text fx:id="textoError" fill="RED" layoutX="250.0"
			layoutY="240.0" text="">
			<font>
				<Font name="MT Extra" size="12.0" />
			</font>
		</Text>

		<!-- BOTÓN INVITADO -->
		<Button layoutX="278.0" layoutY="270.0"
			onAction="#irAMenuJuego" prefHeight="32.0" prefWidth="157.0"
			style="-fx-background-color: linear-gradient(#4b4b4b, #1f1f1f); -fx-background-radius: 40;"
			text="Jugar Como Invitado" textFill="WHITE">
			<font>
				<Font name="MT Extra" size="14.0" />
			</font>
			<cursor>
				<Cursor fx:constant="HAND" />
			</cursor>
		</Button>

		<!-- TÍTULO -->
		<Text fill="#919191" layoutX="157.0" layoutY="353.0"
			text="Código Oculto">
			<font>
				<Font name="MT Extra" size="64.0" />
			</font>
		</Text>

		<Text fill="WHITE" layoutX="160.0" layoutY="353.0"
			text="Código Oculto">
			<font>
				<Font name="MT Extra" size="64.0" />
			</font>
		</Text>

	</children>
</AnchorPane>