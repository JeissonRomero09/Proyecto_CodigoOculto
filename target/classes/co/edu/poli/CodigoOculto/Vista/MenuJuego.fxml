<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="co.edu.poli.CodigoOculto.Controlador.MenuJuegoControlador">

	<children>

		<!-- Fondo -->
		<ImageView fitHeight="463.0" fitWidth="689.0"
			pickOnBounds="true" preserveRatio="true">
			<image>
				<Image url="@/co/edu/poli/CodigoOculto/img/Fondo1.png" />
			</image>
		</ImageView>

		<ImageView fitHeight="484.0" fitWidth="697.0" layoutY="-8.0">
			<image>
				<Image url="@/co/edu/poli/CodigoOculto/img/Fondo2.png" />
			</image>
		</ImageView>

		<!-- BOTÓN JUGAR -->
		<Button layoutX="274.0" layoutY="99.0"
			onAction="#irAPantallaJuego" prefHeight="32.0" prefWidth="157.0"
			style="-fx-background-color: linear-gradient(#4b4b4b, #1f1f1f); -fx-background-radius: 40;"
			text="Jugar Solo" textFill="WHITE">
			<font>
				<Font name="MT Extra" size="14.0" />
			</font>
		</Button>

		<!-- TÍTULO -->
		<Text fill="#919191" layoutX="157.0" layoutY="353.0"
			text="Código Oculto">
			<font>
				<Font name="MT Extra" size="64.0" />
			</font>
		</Text>

		<Text fill="WHITE" layoutX="160.0" layoutY="353.0"
			text="Código Oculto">
			<font>
				<Font name="MT Extra" size="64.0" />
			</font>
		</Text>

		<!-- ID DEL JUGADOR -->
		<Text fx:id="textoId" fill="WHITE" layoutX="14.0" layoutY="25.0"
			text="ID :">
			<font>
				<Font name="MT Extra" size="14.0" />
			</font>
		</Text>

		<!-- NOMBRE DEL JUGADOR (CORREGIDO) -->
		<Text fx:id="textoNombre" fill="WHITE" layoutX="14.0"
			layoutY="45.0" text="Name :">
			<font>
				<Font name="MT Extra" size="14.0" />
			</font>
		</Text>

		<!-- OTROS BOTONES -->
		<Button layoutX="274.0" layoutY="140.0" prefHeight="32.0"
			prefWidth="157.0"
			style="-fx-background-color: linear-gradient(#4b4b4b, #1f1f1f); -fx-background-radius: 40;"
			text="Multijugador" textFill="WHITE">
			<font>
				<Font name="MT Extra" size="14.0" />
			</font>
		</Button>

		<Button layoutX="277.0" layoutY="181.0" prefHeight="32.0"
			prefWidth="157.0"
			style="-fx-background-color: linear-gradient(#4b4b4b, #1f1f1f); -fx-background-radius: 40;"
			text="Ver historial" textFill="WHITE">
			<font>
				<Font name="MT Extra" size="14.0" />
			</font>
		</Button>

		<Button layoutX="277.0" layoutY="222.0" prefHeight="32.0"
			prefWidth="157.0"
			style="-fx-background-color: linear-gradient(#4b4b4b, #1f1f1f); -fx-background-radius: 40;"
			text="Como Jugar" textFill="WHITE">
			<font>
				<Font name="MT Extra" size="14.0" />
			</font>
		</Button>

		<!-- CERRAR SESIÓN -->
		<Button layoutX="525.0" layoutY="21.0" onAction="#cerrarSesion"
			prefHeight="32.0" prefWidth="157.0"
			style="-fx-background-color: linear-gradient(#4b4b4b, #1f1f1f); -fx-background-radius: 40;"
			text="Cerrar Sesión" textFill="WHITE">
			<font>
				<Font name="MT Extra" size="14.0" />
			</font>
		</Button>

	</children>
</AnchorPane>